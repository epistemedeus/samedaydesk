# ── SameDayDesk env (copy to .env for local dev; set these in Hostinger for prod) ──
# Do NOT set PORT — Hostinger injects it. Server binds process.env.PORT || 3000.

NODE_ENV=development
PUBLIC_URL=http://localhost:5173

# ── Supabase (public, also baked into the SPA as VITE_* below) ──
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=          # SECRET — server only, bypasses RLS
SUPABASE_BUCKET=intake-uploads

# ── Stripe (sandbox first; swap to live at go-live) ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...      # from `stripe listen` locally; dashboard endpoint in prod

# ── Resend ── (send from the mail.samedaydesk.com SUBDOMAIN to protect root reputation;
#    replies route to the human contact@ inbox)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=SameDayDesk <hello@mail.samedaydesk.com>
RESEND_REPLY_TO=contact@samedaydesk.com
RESEND_WEBHOOK_SECRET=whsec_...      # Svix secret for bounce/complaint webhook (optional in dev)

# ── Admin gate (env-pinned; never store role flags client-writable) ──
ADMIN_EMAIL=vanbarthelemy@gmail.com
ADMIN_UID=

# ── Client build-time public vars (Vite bakes these into the SPA) ──
# Mirror these into client/.env (or set in Hostinger build env). Public — safe to expose.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_POSTHOG_KEY=
VITE_SITE_URL=http://localhost:5173
