{
  "name": "samedaydesk",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "concurrently -k -n server,client -c green,cyan \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch --env-file=.env server/index.js",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client install --include=dev && npm --prefix client run build",
    "start": "node server/index.js",
    "lint": "npm --prefix client run lint"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "express": "^5.2.1",
    "jose": "^6.2.3",
    "resend": "^6.14.0",
    "stripe": "^22.2.2"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
